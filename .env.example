# =============================================================================
# OmicsClaw Bot — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Only LLM_API_KEY + one platform token are required to get started.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Provider (choose one)
# ---------------------------------------------------------------------------
# Supported: deepseek, gemini, openai, custom
#
#   deepseek  — https://api.deepseek.com  (default model: deepseek-chat)
#   gemini    — Google Gemini via OpenAI-compatible endpoint (default: gemini-2.0-flash)
#   openai    — OpenAI API (default model: gpt-4o)
#   custom    — any OpenAI-compatible endpoint; set LLM_BASE_URL manually
#
# When LLM_PROVIDER is set, LLM_BASE_URL and OMICSCLAW_MODEL are auto-configured
# (you can still override them explicitly).

LLM_PROVIDER=deepseek

# Your API key (required)
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Override base URL (optional — auto-set by LLM_PROVIDER)
# LLM_BASE_URL=https://api.deepseek.com/v1

# Override model name (optional — auto-set by LLM_PROVIDER)
# OMICSCLAW_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# Telegram Bot
# ---------------------------------------------------------------------------
# Get a token from @BotFather on Telegram: https://t.me/BotFather

# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Admin chat ID — bypasses rate limit (optional)
# Get your chat ID by messaging @userinfobot
# TELEGRAM_CHAT_ID=

# Max messages per user per hour (default: 10, 0 = unlimited)
# RATE_LIMIT_PER_HOUR=10

# ---------------------------------------------------------------------------
# Feishu (Lark) Bot
# ---------------------------------------------------------------------------
# Create an app at https://open.feishu.cn/app
# Enable Bot capability + Long Connection mode

# FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Milliseconds before showing "thinking..." placeholder (default: 2500)
# FEISHU_THINKING_THRESHOLD_MS=2500

# Max inbound image size in MB (default: 12)
# FEISHU_MAX_INBOUND_IMAGE_MB=12

# Max inbound file size in MB (default: 40)
# FEISHU_MAX_INBOUND_FILE_MB=40

# Max attachments per message (default: 4)
# FEISHU_MAX_ATTACHMENTS=4

# Enable debug logging (default: 0)
# FEISHU_BRIDGE_DEBUG=0

# ---------------------------------------------------------------------------
# Data directories
# ---------------------------------------------------------------------------
# Comma-separated list of additional trusted directories where the bot may
# read input data files. The bot always trusts data/, examples/, and output/.
# Use this to point to shared NAS, external storage, or other project folders
# without copying files into the project tree.
#
# OMICSCLAW_DATA_DIRS=/mnt/nas/spatial_data,/home/user/experiments

# ---------------------------------------------------------------------------
# Memory System (Optional)
# ---------------------------------------------------------------------------
# Enable persistent conversation memory across bot restarts.
# When enabled, the bot remembers datasets, analyses, and user preferences.
#
# Backend: sqlite (only option currently)
# OMICSCLAW_MEMORY_BACKEND=sqlite
#
# Database path (default: bot/data/memory.db)
# OMICSCLAW_MEMORY_DB_PATH=bot/data/memory.db
#
# Session TTL in days (default: 30)
# OMICSCLAW_MEMORY_TTL_DAYS=30
#
# Encryption key for securing sensitive memory fields (64-character hex string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a temporary random key is generated (memories unreadable after restart)
# ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Bot Behavior Limits
# ---------------------------------------------------------------------------
# Maximum conversation history messages to keep in memory (default: 50)
# Older messages are trimmed but important context is saved to persistent memory
# OMICSCLAW_MAX_HISTORY=50
#
# Maximum tool call iterations per message (default: 20)
# Prevents infinite loops while supporting complex multi-step workflows
# OMICSCLAW_MAX_TOOL_ITERATIONS=20
