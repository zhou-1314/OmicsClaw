# =============================================================================
# OmicsClaw Bot — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# Or use the interactive wizard:
#   oc onboard
#
# To get started with chat/bot flows you need:
#   1. One valid LLM credential (LLM_API_KEY or a provider-specific API key)
#   2. One channel configuration block
#
# The app backend (`oc app-server`) can start without an LLM credential so
# OmicsClaw Desktop can show first-run settings and save the provider there.
#
# OmicsClaw will load this file automatically. Standard KEY=value syntax works
# even when python-dotenv is not installed.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Provider  (Multi-Provider support)
# ---------------------------------------------------------------------------
# OmicsClaw supports 12 LLM providers through a unified OpenAI-compatible
# interface. All providers are accessed through the same AsyncOpenAI client.
#
# HOW IT WORKS:
#   Option 1 — Set LLM_PROVIDER + LLM_API_KEY (explicit)
#   Option 2 — Set only a provider-specific API key (auto-detect)
#              The system picks the first available key in this order:
#              DEEPSEEK → OPENAI → ANTHROPIC → GEMINI → NVIDIA →
#              SILICONFLOW → OPENROUTER → VOLCENGINE → DASHSCOPE → ZHIPU
#
# Supported providers:
#   deepseek    — https://api.deepseek.com       (default: deepseek-v4-flash)
#   openai      — OpenAI API                     (default: gpt-5.5)
#   anthropic   — Anthropic Claude via API        (default: claude-sonnet-4-6)
#   gemini      — Google Gemini via OpenAI compat (default: gemini-3-flash-preview)
#   nvidia      — NVIDIA NIM                     (default: nvidia/nemotron-3-super-120b-a12b)
#   siliconflow — SiliconFlow (硅基流动)           (default: Pro/zai-org/GLM-5)
#   openrouter  — OpenRouter aggregator           (default: anthropic/claude-sonnet-4.6)
#   volcengine  — Volcengine 火山引擎 (Doubao)     (default: doubao-seed-2-0-pro-260215)
#   dashscope   — Alibaba DashScope 阿里云 (Qwen) (default: qwen3.6-plus)
#   moonshot    — Moonshot Kimi                   (default: kimi-k2.6)
#   zhipu       — Zhipu AI 智谱 (GLM)             (default: glm-5.1)
#   ollama      — Local Ollama server             (default: qwen2.5:7b)
#   custom      — Any OpenAI-compatible endpoint

# --- Option 1: Explicit provider + generic key ---
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Option 2: Provider-specific API keys (auto-detected) ---
# Just set the key for your provider — no need for LLM_PROVIDER.
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VOLCENGINE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Option 3: Local LLM Deployment (Ollama) ---
# For total data privacy, use a local model. Ensure your Ollama server is running.
# LLM_PROVIDER=ollama
# OMICSCLAW_MODEL=qwen2.5:7b
# LLM_BASE_URL=http://localhost:11434/v1

# --- Option 4: Custom OpenAI-compatible endpoint ---
# Use this for self-hosted gateways or third-party compatible APIs.
# LLM_PROVIDER=custom
# LLM_BASE_URL=https://your-endpoint.example.com/v1
# OMICSCLAW_MODEL=your-model-name
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Option 5: OAuth login for Claude Pro/Max or OpenAI Codex (via ccproxy) ---
# Uses your existing Claude Pro/Max or OpenAI Codex subscription instead of
# a standalone API key. Requires:
#   1. pip install 'omicsclaw[oauth]'       (installs ccproxy-api)
#      -> You may see a pip warning about `pygpcca 1.0.4 requires jinja2==3.0.3`.
#         This is benign: pygpcca (a cellrank transitive dep) over-pins jinja2;
#         ccproxy-api needs jinja2>=3.1.5 via fastapi[standard]. Both work in
#         practice with jinja2 3.1.x. The install succeeds despite the warning.
#   2. python omicsclaw.py auth login claude    (or: openai)
# Only supported for LLM_PROVIDER=anthropic or openai.
# NOTE: CCPROXY_PORT MUST differ from the app-server port (default 8765) —
# ccproxy would otherwise fail to bind.
# LLM_PROVIDER=anthropic
# LLM_AUTH_MODE=oauth
# CCPROXY_PORT=11435

# Override base URL (optional — auto-set by provider)
# LLM_BASE_URL=https://api.deepseek.com/v1
# Per-provider base URL overrides: <PROVIDER>_BASE_URL (e.g. ANTHROPIC_BASE_URL)

# Override model name (optional — auto-set by provider)
# OMICSCLAW_MODEL=deepseek-v4-flash

# LLM request timeout controls (optional)
# Total timeout applied to each shared AsyncOpenAI request in seconds.
# OMICSCLAW_LLM_TIMEOUT_SECONDS=120
# Connection establishment timeout in seconds.
# OMICSCLAW_LLM_CONNECT_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Telegram Bot
# ---------------------------------------------------------------------------
# Get a token from @BotFather on Telegram: https://t.me/BotFather

# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Admin chat ID — bypasses rate limit (optional)
# Get your chat ID by messaging @userinfobot
# TELEGRAM_CHAT_ID=

# Max messages per user per hour (default: 10, 0 = unlimited)
# RATE_LIMIT_PER_HOUR=10

# ---------------------------------------------------------------------------
# Feishu (Lark) Bot
# ---------------------------------------------------------------------------
# Create an app at https://open.feishu.cn/app
# Enable Bot capability + Long Connection mode

# FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Milliseconds before showing "thinking..." placeholder (default: 2500)
# FEISHU_THINKING_THRESHOLD_MS=2500

# Max inbound image size in MB (default: 12)
# FEISHU_MAX_INBOUND_IMAGE_MB=12

# Max inbound file size in MB (default: 40)
# FEISHU_MAX_INBOUND_FILE_MB=40

# Max attachments per message (default: 4)
# FEISHU_MAX_ATTACHMENTS=4

# Channel-local rate limit per hour (default: 60)
# FEISHU_RATE_LIMIT_PER_HOUR=60

# Enable debug logging (default: 0)
# FEISHU_BRIDGE_DEBUG=0

# ---------------------------------------------------------------------------
# DingTalk Bot
# ---------------------------------------------------------------------------
# Create a robot app at https://open-dev.dingtalk.com
# Enable Stream Mode
#
# DINGTALK_CLIENT_ID=dingxxxxxxxxxxxxxxxx
# DINGTALK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Channel-local rate limit per hour (default: 60)
# DINGTALK_RATE_LIMIT_PER_HOUR=60

# ---------------------------------------------------------------------------
# Discord Bot
# ---------------------------------------------------------------------------
# Create a bot at https://discord.com/developers/applications
#
# DISCORD_BOT_TOKEN=MTIzNDU2Nzg5.xxxx.xxxxx
#
# Channel-local rate limit per hour (default: 60)
# DISCORD_RATE_LIMIT_PER_HOUR=60
#
# Optional proxy URL for outbound Discord traffic
# DISCORD_PROXY=http://127.0.0.1:7890

# ---------------------------------------------------------------------------
# Slack Bot
# ---------------------------------------------------------------------------
# Slack Socket Mode requires both a bot token and an app token.
#
# SLACK_BOT_TOKEN=xoxb-xxxxxxxx-xxxxxxxx-xxxxxxxx
# SLACK_APP_TOKEN=xapp-1-xxxxxxxx-xxxxxxxx-xxxxxxxx
#
# Channel-local rate limit per hour (default: 60)
# SLACK_RATE_LIMIT_PER_HOUR=60

# ---------------------------------------------------------------------------
# WeChat / WeCom Bot
# ---------------------------------------------------------------------------
# Configure either WeCom (企业微信) or WeChat Official Account (公众号).
# If both are set, runtime will prefer the WeCom backend.
#
# --- WeCom (企业微信) ---
# WECOM_CORP_ID=wwxxxxxxxxxxxxxxxx
# WECOM_AGENT_ID=1000002
# WECOM_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Optional callback verification / encrypted mode
# WECOM_TOKEN=xxxxxxxxxxxxxxxx
# WECOM_ENCODING_AES_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WECOM_WEBHOOK_PORT=9001
#
# --- WeChat Official Account (公众号) ---
# WECHAT_APP_ID=wxxxxxxxxxxxxxxxxx
# WECHAT_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Optional callback verification / encrypted mode
# WECHAT_TOKEN=xxxxxxxxxxxxxxxx
# WECHAT_ENCODING_AES_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WECHAT_WEBHOOK_PORT=9001

# ---------------------------------------------------------------------------
# QQ Bot
# ---------------------------------------------------------------------------
# Create a bot at https://q.qq.com/
#
# QQ_APP_ID=xxxxxxxxxx
# QQ_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Optional comma-separated sender allowlist
# QQ_ALLOWED_SENDERS=12345678,87654321
#
# Channel-local rate limit per hour (default: 60)
# QQ_RATE_LIMIT_PER_HOUR=60

# ---------------------------------------------------------------------------
# Email Bot
# ---------------------------------------------------------------------------
# Standard IMAP + SMTP configuration.
#
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USERNAME=omics-bot@example.com
# EMAIL_IMAP_PASSWORD=your-app-password
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USERNAME=omics-bot@example.com
# EMAIL_SMTP_PASSWORD=your-app-password
#
# Optional outbound / polling controls
# EMAIL_FROM_ADDRESS=omics-bot@example.com
# EMAIL_IMAP_MAILBOX=INBOX
# EMAIL_IMAP_USE_SSL=1
# EMAIL_SMTP_STARTTLS=1
# EMAIL_POLL_INTERVAL=30
# EMAIL_MARK_SEEN=1
# EMAIL_ALLOWED_SENDERS=alice@example.com,bob@example.com

# ---------------------------------------------------------------------------
# iMessage Bot (macOS only)
# ---------------------------------------------------------------------------
# Requires the imsg CLI and a signed-in Messages.app session.
#
# IMESSAGE_CLI_PATH=/opt/homebrew/bin/imsg
#
# Optional sender restrictions and defaults
# IMESSAGE_ALLOWED_SENDERS=+1234567890,user@icloud.com
# IMESSAGE_SERVICE=auto
# IMESSAGE_REGION=US

# ---------------------------------------------------------------------------
# Access Control & Middleware
# ---------------------------------------------------------------------------
# Global sender allowlist applied across all channels by runner middleware.
# Leave empty to allow any sender.
#
# ALLOWED_SENDERS=
#
# Global inbound middleware rate limit per hour (default: 120)
# GLOBAL_RATE_LIMIT=120

# ---------------------------------------------------------------------------
# Data directories
# ---------------------------------------------------------------------------
# Comma-separated list of additional trusted directories where the bot may
# read input data files. The bot always trusts data/, examples/, and output/.
# Use this to point to shared NAS, external storage, or other project folders
# without copying files into the project tree.
#
# OMICSCLAW_DATA_DIRS=/mnt/nas/spatial_data,/home/user/experiments
#
# Optional analysis output root. OmicsClaw-App sets this automatically to
# <selected-workspace>/output when the Desktop workspace is synced.
#
# OMICSCLAW_OUTPUT_DIR=/home/user/experiments/output

# ---------------------------------------------------------------------------
# Graph Memory System (Optional)
# ---------------------------------------------------------------------------
# Enable persistent conversation memory across bot restarts and AI agents.
# Uses a centralized graph database to remember datasets, sessions, and ideas.
#
# OMICSCLAW_MEMORY_DB_URL=sqlite+aiosqlite:///~/.config/omicsclaw/memory.db
# Disable memory completely if needed:
# OMICSCLAW_MEMORY_ENABLED=false
#
# Optional for local-only usage. Required if you bind the API to a non-local
# interface such as 0.0.0.0 or a LAN IP.
# OMICSCLAW_MEMORY_API_TOKEN=
#
# Optional: Set the host and port for the dashboard API.
# Default bind is 127.0.0.1:8766 for local-only access.
# OMICSCLAW_MEMORY_HOST=127.0.0.1
# OMICSCLAW_MEMORY_PORT=8766
#

# ---------------------------------------------------------------------------
# Bot Behavior Limits
# ---------------------------------------------------------------------------
# Maximum conversation history messages to keep in memory (default: 50)
# Older messages are trimmed but important context is saved to persistent memory
# OMICSCLAW_MAX_HISTORY=50
#
# Optional character cap for in-memory conversation history (default: 0 = disabled)
# OMICSCLAW_MAX_HISTORY_CHARS=0
#
# Maximum tool call iterations per message (default: 20)
# Prevents infinite loops while supporting complex multi-step workflows
# OMICSCLAW_MAX_TOOL_ITERATIONS=20

# ---------------------------------------------------------------------------
# Research Pipeline (Optional — requires `pip install -e ".[research]"`)
# ---------------------------------------------------------------------------
# The multi-agent research pipeline uses Tavily for web search (literature
# discovery, citation verification, dataset lookup). Get a free API key at:
# https://tavily.com
#
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Override LLM provider/model specifically for the research pipeline
# (falls back to LLM_PROVIDER / OMICSCLAW_MODEL if not set)
# OC_LLM_PROVIDER=deepseek
# OC_LLM_MODEL=deepseek-v4-flash
#
# Notebook execution timeout in seconds (default: 600)
# Increase for deep learning methods (Cell2Location: 1800-3600s)
# OC_NOTEBOOK_TIMEOUT=600
#
# Pipeline recursion limit (default: 500)
# Increase if you see "recursion limit exceeded" errors in complex pipelines
# OC_RECURSION_LIMIT=500

# ---------------------------------------------------------------------------
# Per-Agent Model Override (Optional)
# ---------------------------------------------------------------------------
# Different agents in the research pipeline can use different LLMs.
# For example, planner/reviewer benefit from strong reasoning models,
# while coding-agent benefits from code-generation models.
#
# Pattern: OC_<AGENT>_PROVIDER / OC_<AGENT>_MODEL
# Agent tags: PLANNER, RESEARCH, CODING, ANALYSIS, WRITING, REVIEWER
#
# Resolution priority (most specific wins):
#   OC_PLANNER_MODEL > OC_LLM_MODEL > OMICSCLAW_MODEL > provider default
#
# Examples:
# OC_PLANNER_PROVIDER=deepseek
# OC_PLANNER_MODEL=deepseek-v4-pro
#
# OC_CODING_PROVIDER=anthropic
# OC_CODING_MODEL=claude-sonnet-4-6
#
# OC_REVIEWER_PROVIDER=deepseek
# OC_REVIEWER_MODEL=deepseek-v4-pro
