# .env.ollama.example — run OmicsClaw on a local, tool-capable Gemma 4 via Ollama (no API key).
#
# HOW TO APPLY: OmicsClaw auto-loads <project_root>/.env at the start of the `oc` CLI
# launcher (omicsclaw.py main() -> load_project_dotenv(), before any subcommand runs).
# So either:
#   1) Copy this file to <project_root>/.env, then start `oc desktop-server --host 127.0.0.1 --port 8765`
#      (it loads .env at startup because it goes through the oc CLI launcher), OR
#   2) Run `oc onboard`, pick provider `ollama`, and it writes these same keys to .env, OR
#   3) For a one-off shell:  set -a; source .env.ollama.example; set +a
#
# NOTE: launching `python -m omicsclaw.surfaces.desktop.server` directly bypasses the oc
# CLI launcher and will NOT auto-load this file — always start via `oc desktop-server`.
#
# Prereqs (on the same Linux server that runs oc desktop-server):
#   ollama pull gemma4:12b   # must be gemma4 — gemma3:12b is NOT tool-capable and breaks routing
#   # Confirm install, localhost bind, and per-tag sizes/context at https://ollama.com/library/gemma4/tags
#
# Date: 2026-06-05

# Provider name — selects Ollama (takes precedence over OMICSCLAW_PROVIDER). No API key needed.
LLM_PROVIDER=ollama

# OpenAI-compatible endpoint of the server's local Ollama (localhost-only; never exposed off-box).
# Matches OmicsClaw's hardcoded ollama preset in omicsclaw/providers/registry.py.
LLM_BASE_URL=http://localhost:11434/v1

# Model tag to load — gemma4:12b is the default baseline; step up to gemma4:26b if tools aren't called.
OMICSCLAW_MODEL=gemma4:12b
